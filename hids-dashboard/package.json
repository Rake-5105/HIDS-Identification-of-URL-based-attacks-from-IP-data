{
  "name": "hids-dashboard",
  "version": "1.0.0",
  "description": "HIDS Dashboard - Full-stack intrusion detection visualization",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run flask\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "flask": "python flask_api/app.py",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install && pip install -r flask_api/requirements.txt"
  },
  "keywords": [
    "hids",
    "security",
    "dashboard"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
